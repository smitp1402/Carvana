<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "Carvana AI Onboarding" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="AI-powered car buying experience. No dealership, no stress.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800;14..32,900&family=Newsreader:opsz,ital,wght@6..72,0,300;6..72,0,400;6..72,0,500;6..72,1,400&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
    <style>
      :root {
        /* Modern Minimal Design System */
        --bg-primary: #FFFFFF;
        --bg-secondary: #FAFAF8;
        --bg-tertiary: #F5F5F3;
        --bg-muted: #EEEEEE;
        --text-primary: #0F0F0F;
        --text-secondary: #2A2A2A;
        --text-muted: #6B6B6B;
        --border: #E8E8E8;
        --border-light: #F0F0F0;
        --silver: #999999;
        --light-silver: #D0D0D0;

        /* Single accent — blue */
        --accent: #0066FF;
        --accent-hover: #0052CC;
        --accent-light: #F0F5FF;
        --accent-gradient: linear-gradient(135deg, #0066FF 0%, #0052CC 100%);
        --success: #059669;

        /* Shadows — very subtle */
        --shadow-sm: 0 1px 2px rgba(0,0,0,0.03);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.05);
        --shadow-lg: 0 8px 32px rgba(0,0,0,0.06);
        --shadow-xl: 0 16px 48px rgba(0,0,0,0.08);

        /* Radii */
        --radius-sm: 8px;
        --radius-md: 10px;
        --radius-lg: 16px;
        --radius-xl: 20px;
      }

      * { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
      body { background: var(--bg-secondary); -webkit-font-smoothing: antialiased; }

      /* Serif display font */
      .font-serif { font-family: 'Newsreader', Georgia, serif; }

      /* Glass nav */
      .glass-nav {
        background: rgba(250,250,248,0.9);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
      }

      /* Gradient text — italic blue accent */
      .gradient-text {
        font-family: 'Newsreader', Georgia, serif;
        font-style: italic;
        color: var(--accent);
        -webkit-text-fill-color: var(--accent);
      }

      /* Buttons — clean, no gradients */
      .btn-primary {
        background: var(--text-primary);
        color: white;
        font-weight: 600;
        transition: all 0.2s ease;
        box-shadow: none;
      }
      .btn-primary:hover {
        background: #000;
        transform: translateY(-1px);
      }
      .btn-primary:active { transform: translateY(0); }

      .btn-accent {
        background: var(--text-primary);
        color: white;
        font-weight: 600;
        transition: all 0.2s ease;
      }
      .btn-accent:hover {
        background: #000;
        transform: translateY(-1px);
      }

      .btn-secondary {
        background: transparent;
        color: var(--text-secondary);
        border: 1.5px solid var(--border);
        font-weight: 500;
        transition: all 0.2s ease;
      }
      .btn-secondary:hover {
        border-color: var(--silver);
        transform: translateY(-1px);
      }

      /* Input */
      .input-field {
        border: 1.5px solid var(--border);
        transition: all 0.2s ease;
        outline: none;
        background: white;
        border-radius: var(--radius-md);
      }
      .input-field:focus {
        border-color: var(--text-primary);
        box-shadow: 0 0 0 3px rgba(0,0,0,0.04);
      }

      /* Cards — minimal */
      .card {
        background: white;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        transition: all 0.3s ease;
        box-shadow: var(--shadow-sm);
      }
      .card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateY(-2px);
      }

      /* Badge */
      .badge {
        font-size: 11px;
        letter-spacing: 0.05em;
        font-weight: 600;
        text-transform: uppercase;
      }

      /* Animations */
      .fade-in {
        animation: fadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) both;
      }
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .slide-up {
        animation: slideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      @keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .scale-in {
        animation: scaleIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      @keyframes scaleIn {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
      }

      /* Pulse dot */
      .pulse-dot { position: relative; }
      .pulse-dot::after {
        content: ''; position: absolute; inset: -2px; border-radius: 50%;
        background: inherit; animation: pulse 2s ease-in-out infinite;
      }
      @keyframes pulse {
        0%, 100% { opacity: 0.4; transform: scale(1); }
        50% { opacity: 0; transform: scale(2); }
      }

      .stat-value { font-variant-numeric: tabular-nums; }

      .footer-link { color: var(--text-muted); transition: color 0.15s; }
      .footer-link:hover { color: var(--text-primary); }

      html { scroll-behavior: smooth; }
    </style>
  </head>

  <body class="h-full antialiased text-neutral-900">
    <!-- Nav -->
    <nav class="sticky top-0 z-50 border-b glass-nav" style="border-color: var(--border);">
      <div class="max-w-[1200px] mx-auto px-5 sm:px-8 lg:px-16">
        <div class="flex justify-between items-center h-16">
          <%= link_to root_path, class: "flex items-center gap-3 group" do %>
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--text-primary);">
              <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg>
            </div>
            <span class="text-[17px] font-bold tracking-tight" style="letter-spacing: -0.3px;">Carvana</span>
          <% end %>

          <div class="flex items-center gap-6">
            <% if user_signed_in? %>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background: var(--bg-tertiary);">
                  <span class="text-xs font-semibold" style="color: var(--text-muted);"><%= (current_user.first_name.presence || current_user.email[0]).first.upcase %></span>
                </div>
                <span class="text-sm font-medium hidden sm:block" style="color: var(--text-muted);"><%= current_user.first_name.presence || current_user.email.split("@").first %></span>
              </div>
              <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-[13px] transition-colors", style: "color: var(--silver);" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "text-[13px] transition-colors hover:text-neutral-900", style: "color: var(--text-muted);" %>
              <%= link_to "Get Started", new_user_registration_path, class: "btn-accent text-[13px] px-5 py-2 rounded-lg" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash messages -->
    <% if notice %>
      <div class="border-b border-emerald-100 bg-emerald-50/80 fade-in">
        <div class="max-w-[1200px] mx-auto px-5 sm:px-8 lg:px-16 py-3 flex items-center gap-2">
          <svg class="w-4 h-4 text-emerald-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span class="text-sm text-emerald-700 font-medium"><%= notice %></span>
        </div>
      </div>
    <% end %>
    <% if alert %>
      <div class="border-b border-red-100 bg-red-50/80 fade-in">
        <div class="max-w-[1200px] mx-auto px-5 sm:px-8 lg:px-16 py-3 flex items-center gap-2">
          <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" /></svg>
          <span class="text-sm text-red-600 font-medium"><%= alert %></span>
        </div>
      </div>
    <% end %>

    <main>
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="border-t" style="border-color: var(--border); padding: 48px 0;">
      <div class="max-w-[1200px] mx-auto px-5 sm:px-8 lg:px-16 flex justify-between items-center">
        <div class="flex items-center gap-2">
          <div class="w-6 h-6 rounded-md flex items-center justify-center" style="background: var(--text-primary);">
            <svg class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25"/></svg>
          </div>
          <span class="text-xs" style="color: var(--silver);">Demo prototype for Gauntlet AI</span>
        </div>
        <span class="text-xs" style="color: #ccc;">demo@carvana.com / demo1234</span>
      </div>
    </footer>
  </body>
</html>

<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "Carvana AI Onboarding" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>

  <body class="h-full font-inter">
    <!-- Nav -->
    <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <%= link_to root_path, class: "flex items-center" do %>
            <span class="text-2xl font-bold text-blue-600">carvana</span>
            <span class="ml-2 text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full font-medium">AI</span>
          <% end %>
          <div class="flex items-center gap-4">
            <% if user_signed_in? %>
              <span class="text-sm text-gray-600">Hi, <%= current_user.first_name.presence || current_user.email.split("@").first %></span>
              <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm text-gray-500 hover:text-gray-700" %>
            <% else %>
              <%= link_to "Sign in", new_user_session_path, class: "text-sm text-gray-600 hover:text-blue-600" %>
              <%= link_to "Get Started", new_user_registration_path, class: "bg-blue-600 text-white text-sm px-4 py-2 rounded-lg hover:bg-blue-700" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <!-- Flash messages -->
    <% if notice %>
      <div class="bg-green-50 border-b border-green-200 px-4 py-3 text-sm text-green-800"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="bg-red-50 border-b border-red-200 px-4 py-3 text-sm text-red-800"><%= alert %></div>
    <% end %>

    <main>
      <%= yield %>
    </main>
  </body>
</html>

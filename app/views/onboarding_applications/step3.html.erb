<%= render "progress", application: @application %>

<div class="max-w-3xl mx-auto px-5 py-8 fade-in">
  <%= render "vehicle_card", vehicle: @vehicle %>

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-5">
    <div class="lg:col-span-2">
      <div class="card p-6">
        <h2 class="text-lg font-bold tracking-tight mb-0.5">Documents</h2>
        <p class="text-sm text-neutral-400 mb-5">Scan with your camera or upload a file.</p>

        <!-- Checklist -->
        <div class="bg-amber-50/50 border border-amber-100 rounded-xl p-4 mb-6">
          <p class="text-xs font-medium text-amber-700 uppercase tracking-wider mb-2.5">Required documents</p>
          <ul class="space-y-2 text-sm text-amber-700">
            <li class="flex items-center gap-2.5" id="checklist-license">
              <span class="checklist-icon w-4.5 h-4.5 rounded-full border-[1.5px] border-amber-300 flex items-center justify-center text-[10px] flex-shrink-0" style="width:18px;height:18px"></span>
              Driver's license (front)
            </li>
            <li class="flex items-center gap-2.5" id="checklist-pay_stub">
              <span class="checklist-icon w-4.5 h-4.5 rounded-full border-[1.5px] border-amber-300 flex items-center justify-center text-[10px] flex-shrink-0" style="width:18px;height:18px"></span>
              Recent pay stub
            </li>
            <li class="flex items-center gap-2.5" id="checklist-insurance">
              <span class="checklist-icon w-4.5 h-4.5 rounded-full border-[1.5px] border-amber-300 flex items-center justify-center text-[10px] flex-shrink-0" style="width:18px;height:18px"></span>
              Insurance card
            </li>
          </ul>
        </div>

        <!-- Upload zones -->
        <div class="space-y-3" id="doc-upload-area" data-application-id="<%= @application.id %>" data-csrf="<%= form_authenticity_token %>">
          <% [
            { type: "license", label: "Driver's License", desc: "Name, DOB, address extracted automatically", why: "Federal KYC identity verification" },
            { type: "pay_stub", label: "Pay Stub", desc: "Most recent, showing gross income", why: "Income verification for loan eligibility" },
            { type: "insurance", label: "Insurance Card", desc: "Current policy with coverage dates", why: "Required before vehicle delivery" }
          ].each do |doc| %>
            <div class="doc-zone border border-neutral-200 rounded-xl p-4 transition-all hover:border-neutral-300" id="zone-<%= doc[:type] %>" data-doc-type="<%= doc[:type] %>">
              <div class="flex items-center gap-3.5">
                <div class="w-10 h-10 bg-neutral-100 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-sm"><%= doc[:label] %></p>
                  <p class="text-[11px] text-neutral-400"><%= doc[:desc] %></p>
                </div>
                <div class="flex gap-1.5">
                  <button class="scan-btn btn-primary px-3 py-1.5 rounded-lg text-xs font-medium" data-doc-type="<%= doc[:type] %>">Scan</button>
                  <button class="upload-btn btn-secondary px-3 py-1.5 rounded-lg text-xs font-medium" data-doc-type="<%= doc[:type] %>">Upload</button>
                </div>
              </div>
              <div class="doc-status mt-3 hidden"></div>
              <div class="doc-fields mt-3 hidden"></div>
            </div>
          <% end %>
        </div>

        <!-- Hidden file inputs -->
        <input type="file" id="doc-camera-input" accept="image/*" capture="environment" class="hidden">
        <input type="file" id="doc-file-input" accept="image/*,.pdf" class="hidden">

        <div class="mt-5">
          <%= form_with url: update_step_onboarding_application_path(@application, step: 3), method: :patch do |f| %>
            <%= f.submit "Continue to Review",
                class: "w-full btn-primary py-2.5 rounded-xl text-sm font-semibold cursor-pointer" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="lg:col-span-1">
      <%= render "chatbot_widget",
          application: @application,
          step: 3,
          welcome_messages: [
            "Document step! Tap \"Scan\" and point your camera at each document. I'll extract the info automatically."
          ],
          suggestions: ["Why do you need my license?", "What counts as income proof?", "Is my data secure?"] %>
    </div>
  </div>
</div>

<script>
(function() {
  const area = document.getElementById('doc-upload-area');
  const applicationId = area.dataset.applicationId;
  const csrfToken = area.dataset.csrf;
  const cameraInput = document.getElementById('doc-camera-input');
  const fileInput = document.getElementById('doc-file-input');
  let activeDocType = null;

  const FIELD_LABELS = {
    license: { first_name: 'First Name', last_name: 'Last Name', date_of_birth: 'Date of Birth', address: 'Address', license_number: 'License #' },
    pay_stub: { employer_name: 'Employer', gross_income: 'Gross Pay', pay_period: 'Pay Period', net_income: 'Net Pay' },
    insurance: { policy_number: 'Policy #', carrier: 'Carrier', coverage_start: 'Start Date', coverage_end: 'End Date' }
  };

  area.querySelectorAll('.scan-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { activeDocType = this.dataset.docType; cameraInput.click(); });
  });
  area.querySelectorAll('.upload-btn').forEach(function(btn) {
    btn.addEventListener('click', function() { activeDocType = this.dataset.docType; fileInput.click(); });
  });

  cameraInput.addEventListener('change', handleFileSelected);
  fileInput.addEventListener('change', handleFileSelected);

  function handleFileSelected(e) {
    const file = e.target.files[0];
    if (!file || !activeDocType) return;
    uploadDocument(activeDocType, file);
    e.target.value = '';
  }

  async function uploadDocument(docType, file) {
    const zone = document.getElementById('zone-' + docType);
    const statusEl = zone.querySelector('.doc-status');
    const fieldsEl = zone.querySelector('.doc-fields');

    zone.style.borderColor = '#d4d4d4';
    statusEl.className = 'doc-status mt-3';
    statusEl.innerHTML = '<div class="flex items-center gap-2 text-xs text-neutral-500"><svg class="animate-spin h-3.5 w-3.5" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>Scanning...</div>';
    fieldsEl.className = 'doc-fields mt-3 hidden';

    const formData = new FormData();
    formData.append('file', file);
    formData.append('document_type', docType);
    formData.append('application_id', applicationId);

    try {
      const response = await fetch('/document_uploads', {
        method: 'POST',
        headers: { 'X-CSRF-Token': csrfToken },
        body: formData
      });
      const data = await response.json();
      if (!response.ok) { showError(zone, statusEl, fieldsEl, data.error || 'Upload failed'); return; }
      showSuccess(zone, statusEl, fieldsEl, docType, data);
    } catch (error) {
      showError(zone, statusEl, fieldsEl, 'Network error. Please try again.');
    }
  }

  function showSuccess(zone, statusEl, fieldsEl, docType, data) {
    zone.style.borderColor = '#d1fae5';
    zone.style.background = '#f0fdf4';

    const pct = Math.round((data.confidence || 0) * 100);
    statusEl.className = 'doc-status mt-3';
    statusEl.innerHTML = '<p class="text-xs text-emerald-600 font-medium">Verified &middot; ' + pct + '% confidence</p>';

    const labels = FIELD_LABELS[docType] || {};
    const fields = data.fields || {};
    let html = '<div class="bg-white border border-neutral-100 rounded-lg p-3 space-y-1">';
    for (const [key, value] of Object.entries(fields)) {
      const label = labels[key] || key.replace(/_/g, ' ');
      html += '<div class="flex justify-between text-xs"><span class="text-neutral-400">' + escapeHtml(label) + '</span><span class="font-medium">' + escapeHtml(value) + '</span></div>';
    }
    html += '</div>';
    fieldsEl.className = 'doc-fields mt-3';
    fieldsEl.innerHTML = html;

    updateChecklist(docType, true);
    zone.querySelectorAll('.scan-btn, .upload-btn').forEach(function(btn) {
      btn.disabled = true; btn.style.opacity = '0.4'; btn.style.cursor = 'not-allowed';
    });
  }

  function showError(zone, statusEl, fieldsEl, message) {
    zone.style.borderColor = '#fecaca';
    statusEl.className = 'doc-status mt-3';
    statusEl.innerHTML = '<p class="text-xs text-red-500">' + escapeHtml(message) + ' <button class="underline retry-btn">Retry</button></p>';
    statusEl.querySelector('.retry-btn').addEventListener('click', function() {
      zone.style.borderColor = '#e5e5e5'; statusEl.className = 'doc-status mt-3 hidden';
    });
  }

  function updateChecklist(docType, complete) {
    const item = document.getElementById('checklist-' + docType);
    if (!item) return;
    const icon = item.querySelector('.checklist-icon');
    if (complete) {
      icon.style.borderColor = '#10b981'; icon.style.background = '#10b981'; icon.style.color = 'white';
      icon.textContent = '\u2713';
    }
  }

  function escapeHtml(text) {
    const div = document.createElement('div'); div.textContent = text; return div.innerHTML;
  }
})();
</script>

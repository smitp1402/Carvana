<%= render "progress", application: @application %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <%= render "vehicle_card", vehicle: @vehicle %>

  <div class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2">
      <div class="bg-white rounded-2xl border border-gray-200 p-6">
        <h2 class="text-xl font-bold text-gray-900 mb-1">Upload your documents</h2>
        <p class="text-sm text-gray-500 mb-4">Use your camera for instant auto-fill, or upload a file.</p>

        <!-- Document checklist -->
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6">
          <p class="text-sm font-medium text-amber-800 mb-2">📋 You'll need these 3 documents:</p>
          <ul class="space-y-1 text-sm text-amber-700">
            <li>✓ Driver's license (front)</li>
            <li>✓ Most recent pay stub (or proof of income)</li>
            <li>✓ Current auto insurance card</li>
          </ul>
        </div>

        <!-- Document upload areas -->
        <div class="space-y-4">
          <!-- License -->
          <div class="border-2 border-dashed border-gray-300 rounded-xl p-5 hover:border-blue-400 transition-colors" id="license-zone">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center text-2xl">🪪</div>
              <div class="flex-1">
                <p class="font-medium text-gray-900 text-sm">Driver's License</p>
                <p class="text-xs text-gray-500">We'll extract name, DOB, address automatically</p>
              </div>
              <button class="scan-btn bg-blue-600 text-white px-3 py-2 rounded-lg text-sm hover:bg-blue-700"
                      data-doc-type="license" data-application-id="<%= @application.id %>">
                📷 Scan
              </button>
            </div>
            <div class="license-result mt-3 hidden">
              <div class="bg-green-50 border border-green-200 rounded-lg p-3 text-sm text-green-700">
                ✓ Extracted: <span class="font-medium" id="license-extracted"></span>
              </div>
            </div>
          </div>

          <!-- Pay Stub -->
          <div class="border-2 border-dashed border-gray-300 rounded-xl p-5 hover:border-blue-400 transition-colors">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center text-2xl">💰</div>
              <div class="flex-1">
                <p class="font-medium text-gray-900 text-sm">Pay Stub / Income Proof</p>
                <p class="text-xs text-gray-500">Most recent, showing gross income</p>
              </div>
              <button class="scan-btn bg-blue-600 text-white px-3 py-2 rounded-lg text-sm hover:bg-blue-700"
                      data-doc-type="pay_stub" data-application-id="<%= @application.id %>">
                📷 Scan
              </button>
            </div>
            <div class="pay-stub-result mt-3 hidden">
              <div class="bg-green-50 border border-green-200 rounded-lg p-3 text-sm text-green-700">
                ✓ Extracted: <span class="font-medium" id="pay-stub-extracted"></span>
              </div>
            </div>
          </div>

          <!-- Insurance -->
          <div class="border-2 border-dashed border-gray-300 rounded-xl p-5 hover:border-blue-400 transition-colors">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center text-2xl">🛡️</div>
              <div class="flex-1">
                <p class="font-medium text-gray-900 text-sm">Insurance Card</p>
                <p class="text-xs text-gray-500">Current policy showing coverage dates</p>
              </div>
              <button class="scan-btn bg-blue-600 text-white px-3 py-2 rounded-lg text-sm hover:bg-blue-700"
                      data-doc-type="insurance" data-application-id="<%= @application.id %>">
                📷 Scan
              </button>
            </div>
            <div class="insurance-result mt-3 hidden">
              <div class="bg-green-50 border border-green-200 rounded-lg p-3 text-sm text-green-700">
                ✓ Extracted: <span class="font-medium" id="insurance-extracted"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Hidden file input for camera -->
        <input type="file" id="doc-camera-input" accept="image/*" capture="environment" class="hidden">

        <div class="mt-6">
          <%= form_with url: update_step_onboarding_application_path(@application, step: 3), method: :patch do |f| %>
            <%= f.submit "Continue to Review →",
                class: "w-full bg-blue-600 text-white py-3 rounded-xl font-semibold hover:bg-blue-700 cursor-pointer" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="lg:col-span-1">
      <div id="chatbot-widget" class="bg-white rounded-2xl border border-gray-200 overflow-hidden"
           data-application-id="<%= @application.id %>" data-step="3">
        <div class="bg-blue-600 px-4 py-3 flex items-center gap-3">
          <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center text-white text-sm">AI</div>
          <p class="text-white font-medium text-sm">Carvana Assistant</p>
        </div>
        <div id="chat-messages" class="h-64 overflow-y-auto p-4 space-y-3">
          <div class="flex gap-2">
            <div class="w-6 h-6 bg-blue-100 rounded-full flex items-center justify-center text-xs flex-shrink-0 mt-0.5">AI</div>
            <div class="bg-gray-100 rounded-2xl rounded-tl-none px-4 py-2 text-sm text-gray-700 max-w-xs">
              Document step! Tap "Scan" on each card and point your camera at the document. I'll extract the info automatically. 📷
            </div>
          </div>
          <div class="flex gap-2">
            <div class="w-6 h-6 bg-blue-100 rounded-full flex items-center justify-center text-xs flex-shrink-0 mt-0.5">AI</div>
            <div class="bg-gray-100 rounded-2xl rounded-tl-none px-4 py-2 text-sm text-gray-700 max-w-xs">
              Make sure the document is flat, well-lit, and fully in frame for best results.
            </div>
          </div>
        </div>
        <div class="border-t border-gray-200 p-3">
          <div class="flex gap-2">
            <input type="text" id="chat-input" placeholder="Ask anything..."
                   class="flex-1 px-3 py-2 border border-gray-300 rounded-xl text-sm focus:ring-2 focus:ring-blue-500">
            <button id="chat-send" class="bg-blue-600 text-white px-3 py-2 rounded-xl text-sm hover:bg-blue-700">→</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

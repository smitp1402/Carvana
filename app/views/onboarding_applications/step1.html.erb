<%= render "progress", application: @application %>

<div class="max-w-3xl mx-auto px-5 py-8 fade-in">
  <%= render "vehicle_card", vehicle: @vehicle %>

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-5">
    <!-- Form -->
    <div class="lg:col-span-2">
      <div class="card p-6">
        <h2 class="text-lg font-bold tracking-tight mb-0.5">Pre-qualification</h2>
        <p class="text-sm text-neutral-400 mb-6">Soft credit check — won't affect your score.</p>

        <div class="bg-neutral-50 border border-neutral-100 rounded-xl p-4 mb-6">
          <p class="text-sm text-neutral-600 leading-relaxed">A soft pull shows you real loan options without any credit impact. Hard pulls only happen when you formally accept an offer.</p>
        </div>

        <%= form_with url: update_step_onboarding_application_path(@application, step: 1), method: :patch, class: "space-y-4" do |f| %>
          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1.5">Annual Income</label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-neutral-400 text-sm">$</span>
              <%= f.number_field :annual_income, placeholder: "65,000",
                  class: "w-full pl-7 pr-4 py-2.5 input-field rounded-xl text-sm",
                  value: @application.data["annual_income"] %>
            </div>
            <p class="text-[11px] text-neutral-400 mt-1">Used to determine loan eligibility</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1.5">Employment Status</label>
            <%= f.select :employment_status,
                [["Full-time employed", "full_time"], ["Part-time employed", "part_time"], ["Self-employed", "self_employed"], ["Retired", "retired"], ["Other", "other"]],
                { selected: @application.data["employment_status"], prompt: "Select your status" },
                class: "w-full px-4 py-2.5 input-field rounded-xl text-sm" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1.5">Employer Name</label>
            <%= f.text_field :employer_name, placeholder: "Company Inc.",
                class: "w-full px-4 py-2.5 input-field rounded-xl text-sm",
                value: @application.data["employer_name"] %>
          </div>

          <div class="flex items-center gap-2 text-[11px] text-neutral-400 pt-1">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
            Encrypted and never sold. Used only to find your best rate.
          </div>

          <%= f.submit "Continue to Financing",
              class: "w-full btn-primary py-2.5 rounded-xl text-sm font-semibold cursor-pointer mt-2" %>
        <% end %>
      </div>
    </div>

    <!-- AI Chatbot -->
    <div class="lg:col-span-1">
      <%= render "chatbot_widget",
          application: @application,
          step: 1,
          welcome_messages: [
            "Hi! I'll guide you through buying your #{@vehicle.display_name}.",
            "First up: a quick income check for a soft credit pull. This won't affect your score."
          ],
          suggestions: ["What is a soft credit check?", "Why do you need my income?", "How long does this take?"] %>
    </div>
  </div>
</div>

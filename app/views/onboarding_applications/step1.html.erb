<%= render "progress", application: @application %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <%= render "vehicle_card", vehicle: @vehicle %>

  <div class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Form -->
    <div class="lg:col-span-2">
      <div class="bg-white rounded-2xl border border-gray-200 p-6">
        <h2 class="text-xl font-bold text-gray-900 mb-1">Let's check your pre-qualification</h2>
        <p class="text-sm text-gray-500 mb-6">This is a soft credit check — it won't affect your credit score.</p>

        <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6 flex gap-3">
          <span class="text-blue-600 text-lg">ℹ️</span>
          <div>
            <p class="text-sm font-medium text-blue-800">Why we check this</p>
            <p class="text-sm text-blue-700">A soft pull lets us show you real loan options without any impact to your credit score. You'll only see hard pulls when you formally accept a loan offer.</p>
          </div>
        </div>

        <%= form_with url: update_step_onboarding_application_path(@application, step: 1), method: :patch, class: "space-y-5" do |f| %>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              Annual Income
              <span class="text-gray-400 font-normal text-xs ml-1">— Why we ask: determines your loan eligibility</span>
            </label>
            <div class="relative">
              <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">$</span>
              <%= f.number_field :annual_income, placeholder: "65,000",
                  class: "w-full pl-7 pr-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent",
                  value: @application.data["annual_income"] %>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Employment Status</label>
            <%= f.select :employment_status,
                [["Full-time employed", "full_time"], ["Part-time employed", "part_time"], ["Self-employed", "self_employed"], ["Retired", "retired"], ["Other", "other"]],
                { selected: @application.data["employment_status"], prompt: "Select your status" },
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Employer Name</label>
            <%= f.text_field :employer_name, placeholder: "Company Inc.",
                class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500",
                value: @application.data["employer_name"] %>
          </div>

          <div class="bg-green-50 border border-green-200 rounded-xl p-4 flex gap-3">
            <span class="text-green-600">🔒</span>
            <p class="text-sm text-green-700">Your information is encrypted and never sold. We use it only to find you the best loan rate.</p>
          </div>

          <%= f.submit "Continue to Financing →",
              class: "w-full bg-blue-600 text-white py-3 rounded-xl font-semibold hover:bg-blue-700 cursor-pointer transition-colors" %>
        <% end %>
      </div>
    </div>

    <!-- AI Chatbot -->
    <div class="lg:col-span-1">
      <%= render "chatbot_widget",
          application: @application,
          step: 1,
          welcome_messages: [
            "Hi! I'm your Carvana AI assistant. I'll guide you through buying your #{@vehicle.display_name}. Ready to get started?",
            "First, I'll need some income info for a soft credit check. This won't affect your score at all — promise!"
          ],
          suggestions: ["What is a soft credit check?", "Why do you need my income?", "How long does this take?"] %>
    </div>
  </div>
</div>

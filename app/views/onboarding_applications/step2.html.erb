<%= render "progress", application: @application %>

<div class="max-w-3xl mx-auto px-5 py-8 fade-in">
  <%= render "vehicle_card", vehicle: @vehicle %>

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-5">
    <div class="lg:col-span-2">
      <div class="card p-6">
        <h2 class="text-lg font-bold tracking-tight mb-0.5">Financing</h2>
        <p class="text-sm text-neutral-400 mb-6">Adjust terms to find a payment that works.</p>

        <!-- Loan Visualizer -->
        <div class="bg-neutral-900 rounded-2xl p-5 text-white mb-6">
          <p class="text-neutral-400 text-xs uppercase tracking-wider font-medium mb-1">Estimated monthly payment</p>
          <p class="text-3xl font-bold tracking-tight" id="monthly-payment">$487</p>
          <p class="text-neutral-500 text-xs mt-0.5">6.9% APR &middot; <span id="loan-term-display">60</span> months</p>

          <div class="mt-5 space-y-4">
            <div>
              <div class="flex justify-between text-xs text-neutral-400 mb-1.5">
                <span>Loan Term</span>
                <span class="text-white font-medium" id="term-value">60 months</span>
              </div>
              <input type="range" id="loan-term-slider" min="24" max="84" step="12" value="60"
                     class="w-full accent-white cursor-pointer h-1.5">
            </div>
            <div>
              <div class="flex justify-between text-xs text-neutral-400 mb-1.5">
                <span>Down Payment</span>
                <span class="text-white font-medium">$<span id="down-payment-display">2,000</span></span>
              </div>
              <input type="range" id="down-payment-slider" min="0" max="10000" step="500" value="2000"
                     class="w-full accent-white cursor-pointer h-1.5">
            </div>
          </div>
        </div>

        <!-- Jargon explainers -->
        <div class="space-y-2 mb-6">
          <details class="group border border-neutral-100 rounded-xl">
            <summary class="px-4 py-2.5 text-sm text-neutral-600 cursor-pointer flex justify-between items-center">
              <span>What is APR?</span>
              <svg class="w-4 h-4 text-neutral-300 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </summary>
            <p class="px-4 pb-3 text-sm text-neutral-400 leading-relaxed">Annual Percentage Rate — the yearly cost of your loan including interest and fees. Lower APR means less paid over time.</p>
          </details>
          <details class="group border border-neutral-100 rounded-xl">
            <summary class="px-4 py-2.5 text-sm text-neutral-600 cursor-pointer flex justify-between items-center">
              <span>What is GAP insurance?</span>
              <svg class="w-4 h-4 text-neutral-300 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
            </summary>
            <p class="px-4 pb-3 text-sm text-neutral-400 leading-relaxed">Covers the gap between your insurance payout and your loan balance if the car is totaled. Useful if you put less than 20% down.</p>
          </details>
        </div>

        <!-- Confidence prompt -->
        <div class="bg-emerald-50 border border-emerald-100 rounded-xl p-3.5 mb-5 text-sm text-emerald-700">
          These terms aren't final — you can adjust them anytime before signing.
        </div>

        <%= form_with url: update_step_onboarding_application_path(@application, step: 2), method: :patch, class: "space-y-4" do |f| %>
          <%= f.hidden_field :loan_term, id: "loan-term-input", value: @application.data["loan_term"] || 60 %>
          <%= f.hidden_field :down_payment, id: "down-payment-input", value: @application.data["down_payment"] || 2000 %>

          <div>
            <label class="block text-sm font-medium text-neutral-700 mb-1.5">SSN Last 4 Digits</label>
            <%= f.text_field :ssn_last4, placeholder: "1234", maxlength: 4,
                class: "w-full px-4 py-2.5 input-field rounded-xl text-sm",
                value: @application.data["ssn_last4"] %>
            <p class="text-[11px] text-neutral-400 mt-1 flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>
              Encrypted, never stored in plain text
            </p>
          </div>

          <%= f.submit "Continue to Documents",
              class: "w-full btn-primary py-2.5 rounded-xl text-sm font-semibold cursor-pointer" %>
        <% end %>
      </div>
    </div>

    <div class="lg:col-span-1">
      <%= render "chatbot_widget",
          application: @application,
          step: 2,
          welcome_messages: [
            "Nice work on step 1! Use the sliders to find a monthly payment you're comfortable with."
          ],
          suggestions: ["What is APR?", "What is GAP insurance?", "What loan term should I pick?"] %>
    </div>
  </div>
</div>

<script>
  const vehiclePrice = <%= @vehicle.price %>;
  const apr = 0.069;

  function calcPayment(term, down) {
    const principal = vehiclePrice - down;
    const monthlyRate = apr / 12;
    return Math.round(principal * (monthlyRate * Math.pow(1 + monthlyRate, term)) / (Math.pow(1 + monthlyRate, term) - 1));
  }

  function formatNumber(n) {
    return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
  }

  function updateDisplay() {
    const term = parseInt(document.getElementById("loan-term-slider").value);
    const down = parseInt(document.getElementById("down-payment-slider").value);
    document.getElementById("monthly-payment").textContent = "$" + formatNumber(calcPayment(term, down));
    document.getElementById("loan-term-display").textContent = term;
    document.getElementById("term-value").textContent = term + " months";
    document.getElementById("down-payment-display").textContent = formatNumber(down);
    document.getElementById("loan-term-input").value = term;
    document.getElementById("down-payment-input").value = down;
  }

  document.getElementById("loan-term-slider").addEventListener("input", updateDisplay);
  document.getElementById("down-payment-slider").addEventListener("input", updateDisplay);
  updateDisplay();
</script>

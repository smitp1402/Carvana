<div class="bg-blue-50 border border-blue-200 rounded-xl p-4 flex gap-4 items-center">
  <div class="w-14 h-14 bg-white rounded-lg flex items-center justify-center text-3xl flex-shrink-0 border border-blue-100">🚗</div>
  <div class="flex-1 min-w-0">
    <p class="font-semibold text-gray-900 text-sm"><%= vehicle.display_name %></p>
    <p class="text-blue-700 font-bold"><%= vehicle.formatted_price %></p>
    <p class="text-xs text-gray-500"><%= vehicle.formatted_mileage %> · <%= vehicle.color %></p>
  </div>
  <div class="text-right flex-shrink-0">
    <p class="text-xs text-gray-500">Stock</p>
    <p class="text-xs font-mono font-medium text-gray-700">#<%= vehicle.stock_no %></p>
  </div>
</div>

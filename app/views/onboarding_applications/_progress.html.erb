<%
  steps = [
    { num: 1, label: "Pre-Qualify" },
    { num: 2, label: "Financing" },
    { num: 3, label: "Documents" },
    { num: 4, label: "Review" },
    { num: 5, label: "Done" }
  ]
%>
<div class="bg-white border-b border-gray-200 px-4 py-4">
  <div class="max-w-3xl mx-auto">
    <div class="flex items-center justify-between">
      <% steps.each_with_index do |s, i| %>
        <% is_done = application.current_step > s[:num] %>
        <% is_current = application.current_step == s[:num] %>
        <div class="flex flex-col items-center">
          <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-semibold
            <%= is_done ? 'bg-green-500 text-white' : is_current ? 'bg-blue-600 text-white ring-4 ring-blue-100' : 'bg-gray-100 text-gray-400' %>">
            <% if is_done %>✓<% else %><%= s[:num] %><% end %>
          </div>
          <span class="text-xs mt-1 hidden sm:block
            <%= is_current ? 'text-blue-600 font-medium' : is_done ? 'text-green-600' : 'text-gray-400' %>">
            <%= s[:label] %>
          </span>
        </div>
        <% unless i == steps.length - 1 %>
          <div class="flex-1 h-0.5 mx-2 <%= application.current_step > s[:num] ? 'bg-green-400' : 'bg-gray-200' %>"></div>
        <% end %>
      <% end %>
    </div>
    <div class="mt-3 text-center">
      <span class="text-xs text-gray-500">Step <%= application.current_step %> of 5 · <%= application.progress_percentage %>% complete</span>
    </div>
  </div>
</div>

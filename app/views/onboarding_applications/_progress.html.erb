<%
  steps = [
    { num: 1, label: "Pre-Qualify" },
    { num: 2, label: "Financing" },
    { num: 3, label: "Documents" },
    { num: 4, label: "Review" },
    { num: 5, label: "Done" }
  ]
%>
<div class="border-b border-neutral-100 bg-white px-5 py-4">
  <div class="max-w-xl mx-auto">
    <div class="flex items-center justify-between">
      <% steps.each_with_index do |s, i| %>
        <% is_done = application.current_step > s[:num] %>
        <% is_current = application.current_step == s[:num] %>
        <div class="flex flex-col items-center">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-semibold transition-all
            <%= is_done ? 'bg-neutral-900 text-white' : is_current ? 'bg-neutral-900 text-white ring-[3px] ring-neutral-200' : 'bg-neutral-100 text-neutral-400' %>">
            <% if is_done %>
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            <% else %>
              <%= s[:num] %>
            <% end %>
          </div>
          <span class="text-[10px] mt-1.5 hidden sm:block font-medium
            <%= is_current ? 'text-neutral-900' : is_done ? 'text-neutral-500' : 'text-neutral-300' %>">
            <%= s[:label] %>
          </span>
        </div>
        <% unless i == steps.length - 1 %>
          <div class="flex-1 h-px mx-3 <%= application.current_step > s[:num] ? 'bg-neutral-900' : 'bg-neutral-200' %>"></div>
        <% end %>
      <% end %>
    </div>
    <% milestone = case application.current_step
         when 2 then "Pre-qualification complete"
         when 3 then "Financing locked in"
         when 4 then "Documents uploaded"
         when 5 then "All done!"
       end %>
    <div class="text-center mt-3">
      <span class="text-[11px] text-neutral-400">Step <%= application.current_step %> of 5</span>
      <% if milestone %>
        <span class="text-[11px] text-emerald-600 font-medium ml-2">&middot; <%= milestone %></span>
      <% end %>
    </div>
  </div>
</div>

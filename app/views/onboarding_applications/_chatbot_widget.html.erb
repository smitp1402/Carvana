<div id="chatbot-widget"
     class="card overflow-hidden h-full flex flex-col"
     data-application-id="<%= application.id %>"
     data-step="<%= step %>"
     data-csrf="<%= form_authenticity_token %>">
  <!-- Header -->
  <div class="px-4 py-3 flex items-center gap-3 flex-shrink-0 border-b border-neutral-100">
    <div class="w-7 h-7 bg-neutral-900 rounded-lg flex items-center justify-center">
      <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
    </div>
    <div>
      <p class="font-medium text-sm">AI Assistant</p>
      <p class="text-[11px] text-neutral-400" id="chatbot-status">Online</p>
    </div>
  </div>

  <!-- Messages -->
  <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-3" style="min-height: 240px; max-height: 380px;">
    <% if local_assigns[:welcome_messages] && application.chat_messages.empty? %>
      <% welcome_messages.each do |msg| %>
        <div class="flex gap-2.5">
          <div class="w-5 h-5 bg-neutral-900 rounded-md flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
          </div>
          <div class="bg-neutral-50 border border-neutral-100 rounded-2xl rounded-tl-md px-3.5 py-2 text-sm text-neutral-700 leading-relaxed max-w-[260px]">
            <%= msg %>
          </div>
        </div>
      <% end %>
    <% end %>

    <% application.chat_messages.order(created_at: :asc).each do |msg| %>
      <% if msg.role == "assistant" %>
        <div class="flex gap-2.5">
          <div class="w-5 h-5 bg-neutral-900 rounded-md flex items-center justify-center flex-shrink-0 mt-0.5">
            <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
          </div>
          <div class="bg-neutral-50 border border-neutral-100 rounded-2xl rounded-tl-md px-3.5 py-2 text-sm text-neutral-700 leading-relaxed max-w-[260px]">
            <%= msg.content %>
          </div>
        </div>
      <% else %>
        <div class="flex gap-2 justify-end">
          <div class="bg-neutral-900 rounded-2xl rounded-tr-md px-3.5 py-2 text-sm text-white max-w-[260px]">
            <%= msg.content %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- Quick suggestions -->
  <% if local_assigns[:suggestions] && suggestions.any? %>
    <div id="chat-suggestions" class="px-4 pb-2 flex flex-wrap gap-1.5">
      <% suggestions.each do |s| %>
        <button class="chat-suggestion text-[11px] bg-neutral-50 text-neutral-600 px-2.5 py-1 rounded-lg border border-neutral-100 hover:border-neutral-300 transition-colors cursor-pointer">
          <%= s %>
        </button>
      <% end %>
    </div>
  <% end %>

  <!-- Input -->
  <div class="border-t border-neutral-100 p-3 flex-shrink-0">
    <div class="flex gap-2">
      <input type="text" id="chat-input" placeholder="Ask anything..."
             class="flex-1 px-3 py-2 input-field rounded-lg text-sm"
             autocomplete="off">
      <button id="chat-send" class="btn-primary px-3.5 py-2 rounded-lg text-sm font-medium disabled:opacity-40 disabled:cursor-not-allowed disabled:transform-none disabled:shadow-none">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" /></svg>
      </button>
    </div>
  </div>
</div>

<script>
(function() {
  const widget = document.getElementById('chatbot-widget');
  const messagesEl = document.getElementById('chat-messages');
  const inputEl = document.getElementById('chat-input');
  const sendBtn = document.getElementById('chat-send');
  const statusEl = document.getElementById('chatbot-status');
  const suggestionsEl = document.getElementById('chat-suggestions');

  const applicationId = widget.dataset.applicationId;
  const step = widget.dataset.step;
  const csrfToken = widget.dataset.csrf;

  let sending = false;

  function scrollToBottom() {
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function appendMessage(role, content) {
    const wrapper = document.createElement('div');
    wrapper.className = 'flex gap-2.5' + (role === 'user' ? ' justify-end' : '') + ' fade-in';

    if (role === 'assistant') {
      wrapper.innerHTML =
        '<div class="w-5 h-5 bg-neutral-900 rounded-md flex items-center justify-center flex-shrink-0 mt-0.5"><svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg></div>' +
        '<div class="bg-neutral-50 border border-neutral-100 rounded-2xl rounded-tl-md px-3.5 py-2 text-sm text-neutral-700 leading-relaxed max-w-[260px]">' +
        escapeHtml(content) + '</div>';
    } else {
      wrapper.innerHTML =
        '<div class="bg-neutral-900 rounded-2xl rounded-tr-md px-3.5 py-2 text-sm text-white max-w-[260px]">' +
        escapeHtml(content) + '</div>';
    }

    messagesEl.appendChild(wrapper);
    scrollToBottom();
    return wrapper;
  }

  function createStreamingMessage() {
    const wrapper = document.createElement('div');
    wrapper.className = 'flex gap-2.5 fade-in';
    wrapper.innerHTML =
      '<div class="w-5 h-5 bg-neutral-900 rounded-md flex items-center justify-center flex-shrink-0 mt-0.5"><svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg></div>' +
      '<div class="bg-neutral-50 border border-neutral-100 rounded-2xl rounded-tl-md px-3.5 py-2 text-sm text-neutral-700 leading-relaxed max-w-[260px] streaming-content"></div>';
    messagesEl.appendChild(wrapper);
    scrollToBottom();
    return wrapper.querySelector('.streaming-content');
  }

  function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function setLoading(isLoading) {
    sending = isLoading;
    sendBtn.disabled = isLoading;
    inputEl.disabled = isLoading;
    statusEl.textContent = isLoading ? 'Typing...' : 'Online';
  }

  async function sendMessage(message) {
    if (!message.trim() || sending) return;

    if (suggestionsEl) suggestionsEl.style.display = 'none';

    appendMessage('user', message);
    inputEl.value = '';
    setLoading(true);

    try {
      const response = await fetch('/chat_messages?stream=true', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': csrfToken,
          'Accept': 'text/event-stream'
        },
        body: JSON.stringify({
          application_id: applicationId,
          step: step,
          message: message
        })
      });

      if (!response.ok) throw new Error('Failed to send message');

      const contentType = response.headers.get('content-type') || '';

      if (contentType.includes('text/event-stream')) {
        const streamEl = createStreamingMessage();
        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;

          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() || '';

          for (const line of lines) {
            const trimmed = line.trim();
            if (trimmed.startsWith('data: ')) {
              try {
                const data = JSON.parse(trimmed.slice(6));
                if (data.token) {
                  streamEl.textContent += data.token;
                  scrollToBottom();
                }
              } catch (e) {}
            }
          }
        }
      } else {
        const data = await response.json();
        appendMessage('assistant', data.content);
      }
    } catch (error) {
      console.error('Chat error:', error);
      appendMessage('assistant', "I'm having trouble connecting. You can continue filling out the form — I'll be back shortly!");
    } finally {
      setLoading(false);
    }
  }

  sendBtn.addEventListener('click', function() { sendMessage(inputEl.value); });
  inputEl.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(inputEl.value); }
  });

  if (suggestionsEl) {
    suggestionsEl.querySelectorAll('.chat-suggestion').forEach(function(btn) {
      btn.addEventListener('click', function() { sendMessage(this.textContent.trim()); });
    });
  }

  scrollToBottom();

  // Inactivity re-engagement (3 minutes)
  let inactivityTimer = null;
  let reEngaged = false;

  function resetInactivityTimer() {
    if (reEngaged) return;
    clearTimeout(inactivityTimer);
    inactivityTimer = setTimeout(function() {
      if (!reEngaged && !sending) {
        reEngaged = true;
        appendMessage('assistant', "Still thinking? I can help explain anything on this page.");
      }
    }, 180000);
  }

  document.addEventListener('mousemove', resetInactivityTimer);
  document.addEventListener('keydown', resetInactivityTimer);
  document.addEventListener('scroll', resetInactivityTimer);
  document.addEventListener('touchstart', resetInactivityTimer);
  resetInactivityTimer();
})();
</script>

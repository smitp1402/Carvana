<%= render "progress", application: @application %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <%= render "vehicle_card", vehicle: @vehicle %>

  <div class="mt-8 grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2">
  <div class="bg-white rounded-2xl border border-gray-200 p-6">
    <h2 class="text-xl font-bold text-gray-900 mb-1">Review your application</h2>
    <p class="text-sm text-gray-500 mb-6">Almost there! Review your details before submitting.</p>

    <!-- Purchase confidence prompt -->
    <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6 flex gap-3">
      <span class="text-2xl">🎉</span>
      <div>
        <p class="font-medium text-green-800 text-sm">You're making a great choice</p>
        <p class="text-sm text-green-700">The <%= @vehicle.display_name %> has excellent reliability ratings and comes with Carvana's 100-day/4,189-mile return policy. You can change your mind after delivery.</p>
      </div>
    </div>

    <!-- Application summary -->
    <div class="space-y-4 mb-6">
      <div class="border border-gray-200 rounded-xl overflow-hidden">
        <div class="bg-gray-50 px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Vehicle</div>
        <div class="px-4 py-3 flex justify-between text-sm">
          <span class="text-gray-600">Selected Vehicle</span>
          <span class="font-medium"><%= @vehicle.display_name %></span>
        </div>
        <div class="px-4 py-3 border-t border-gray-100 flex justify-between text-sm">
          <span class="text-gray-600">Purchase Price</span>
          <span class="font-bold text-blue-600"><%= @vehicle.formatted_price %></span>
        </div>
      </div>

      <div class="border border-gray-200 rounded-xl overflow-hidden">
        <div class="bg-gray-50 px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Financing</div>
        <div class="px-4 py-3 flex justify-between text-sm">
          <span class="text-gray-600">Loan Term</span>
          <span class="font-medium"><%= @application.data["loan_term"] || 60 %> months</span>
        </div>
        <div class="px-4 py-3 border-t border-gray-100 flex justify-between text-sm">
          <span class="text-gray-600">Down Payment</span>
          <span class="font-medium">$<%= @application.data["down_payment"] || "2,000" %></span>
        </div>
        <div class="px-4 py-3 border-t border-gray-100 flex justify-between text-sm">
          <span class="text-gray-600">APR</span>
          <span class="font-medium">6.9%</span>
        </div>
      </div>

      <div class="border border-gray-200 rounded-xl overflow-hidden">
        <div class="bg-gray-50 px-4 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wider">Income</div>
        <div class="px-4 py-3 flex justify-between text-sm">
          <span class="text-gray-600">Annual Income</span>
          <span class="font-medium">$<%= @application.data["annual_income"] || "—" %></span>
        </div>
        <div class="px-4 py-3 border-t border-gray-100 flex justify-between text-sm">
          <span class="text-gray-600">Employment</span>
          <span class="font-medium"><%= @application.data["employment_status"]&.humanize || "—" %></span>
        </div>
      </div>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6 text-sm text-blue-700">
      By submitting, you authorize Carvana to pull your full credit report. This will appear as a hard inquiry on your credit report.
    </div>

    <%= form_with url: update_step_onboarding_application_path(@application, step: 4), method: :patch do |f| %>
      <%= f.submit "Submit Application ✓",
          class: "w-full bg-green-600 text-white py-4 rounded-xl font-bold text-lg hover:bg-green-700 cursor-pointer" %>
    <% end %>
  </div>
  </div>

    <!-- AI Chatbot -->
    <div class="lg:col-span-1">
      <%= render "chatbot_widget",
          application: @application,
          step: 4,
          welcome_messages: [
            "You're almost there! Review everything above and hit submit when you're ready. I'm here if you have any last questions."
          ],
          suggestions: ["Can I change my terms later?", "What is a hard inquiry?", "What happens after I submit?"] %>
    </div>
  </div>
</div>

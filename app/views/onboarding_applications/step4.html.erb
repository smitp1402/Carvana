<%= render "progress", application: @application %>

<div class="max-w-3xl mx-auto px-5 py-8 fade-in">
  <%= render "vehicle_card", vehicle: @vehicle %>

  <div class="mt-6 grid grid-cols-1 lg:grid-cols-3 gap-5">
    <div class="lg:col-span-2">
      <div class="card p-6">
        <h2 class="text-lg font-bold tracking-tight mb-0.5">Review</h2>
        <p class="text-sm text-neutral-400 mb-6">Confirm your details before submitting.</p>

        <!-- Confidence -->
        <div class="bg-emerald-50 border border-emerald-100 rounded-xl p-4 mb-6">
          <p class="text-sm font-medium text-emerald-700 mb-0.5">You're making a great choice</p>
          <p class="text-xs text-emerald-600 leading-relaxed"><%= @vehicle.display_name %> comes with Carvana's 100-day / 4,189-mile return policy.</p>
        </div>

        <!-- Summary -->
        <div class="space-y-3 mb-6">
          <div class="border border-neutral-100 rounded-xl overflow-hidden">
            <div class="bg-neutral-50 px-4 py-2 text-[10px] font-semibold text-neutral-400 uppercase tracking-wider">Vehicle</div>
            <div class="divide-y divide-neutral-50">
              <div class="px-4 py-2.5 flex justify-between text-sm">
                <span class="text-neutral-400">Vehicle</span>
                <span class="font-medium"><%= @vehicle.display_name %></span>
              </div>
              <div class="px-4 py-2.5 flex justify-between text-sm">
                <span class="text-neutral-400">Price</span>
                <span class="font-bold"><%= @vehicle.formatted_price %></span>
              </div>
            </div>
          </div>

          <div class="border border-neutral-100 rounded-xl overflow-hidden">
            <div class="bg-neutral-50 px-4 py-2 text-[10px] font-semibold text-neutral-400 uppercase tracking-wider">Financing</div>
            <div class="divide-y divide-neutral-50">
              <div class="px-4 py-2.5 flex justify-between text-sm">
                <span class="text-neutral-400">Loan Term</span>
                <span class="font-medium"><%= @application.data["loan_term"] || 60 %> months</span>
              </div>
              <div class="px-4 py-2.5 flex justify-between text-sm">
                <span class="text-neutral-400">Down Payment</span>
                <span class="font-medium">$<%= @application.data["down_payment"] || "2,000" %></span>
              </div>
              <div class="px-4 py-2.5 flex justify-between text-sm">
                <span class="text-neutral-400">APR</span>
                <span class="font-medium">6.9%</span>
              </div>
            </div>
          </div>

          <div class="border border-neutral-100 rounded-xl overflow-hidden">
            <div class="bg-neutral-50 px-4 py-2 text-[10px] font-semibold text-neutral-400 uppercase tracking-wider">Income</div>
            <div class="divide-y divide-neutral-50">
              <div class="px-4 py-2.5 flex justify-between text-sm">
                <span class="text-neutral-400">Annual Income</span>
                <span class="font-medium">$<%= @application.data["annual_income"] || "—" %></span>
              </div>
              <div class="px-4 py-2.5 flex justify-between text-sm">
                <span class="text-neutral-400">Employment</span>
                <span class="font-medium"><%= @application.data["employment_status"]&.humanize || "—" %></span>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-neutral-50 border border-neutral-100 rounded-xl p-3.5 mb-5 text-xs text-neutral-500 leading-relaxed">
          By submitting, you authorize a full credit report pull. This appears as a hard inquiry on your credit report.
        </div>

        <%= form_with url: update_step_onboarding_application_path(@application, step: 4), method: :patch do |f| %>
          <%= f.submit "Submit Application",
              class: "w-full bg-emerald-600 hover:bg-emerald-700 text-white py-3 rounded-xl text-sm font-bold cursor-pointer transition-all hover:-translate-y-0.5 hover:shadow-lg" %>
        <% end %>
      </div>
    </div>

    <div class="lg:col-span-1">
      <%= render "chatbot_widget",
          application: @application,
          step: 4,
          welcome_messages: [
            "Almost there! Review everything above. I'm here for any last questions."
          ],
          suggestions: ["Can I change my terms later?", "What is a hard inquiry?", "What happens after I submit?"] %>
    </div>
  </div>
</div>

<!-- Hero Section -->
<section class="slide-up">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-8 lg:px-16 py-24 sm:py-28 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">
      <!-- Left: Copy -->
      <div>
        <div class="text-[11px] font-semibold tracking-[2px] uppercase mb-6" style="color: var(--silver);">AI-Powered Onboarding</div>

        <h1 class="font-serif text-[48px] sm:text-[56px] font-normal leading-[1.1] mb-6" style="letter-spacing: -1.5px;">
          Buy your next car,<br>
          <em class="gradient-text">guided by AI</em>
        </h1>

        <p class="text-base leading-[1.7] max-w-[420px] mb-10" style="color: var(--text-muted);">
          No dealership. No stress. AI walks you through financing, scans your documents instantly, and delivers to your door.
        </p>

        <div class="flex flex-wrap gap-3 mb-14">
          <% if user_signed_in? %>
            <a href="#inventory" class="btn-primary px-8 py-3.5 rounded-[10px] text-sm inline-flex items-center gap-2">
              Browse Inventory
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" /></svg>
            </a>
          <% else %>
            <%= link_to new_user_registration_path, class: "btn-primary px-8 py-3.5 rounded-[10px] text-sm inline-flex items-center gap-2" do %>
              Get Started Free
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            <% end %>
            <%= link_to "Sign in", new_user_session_path, class: "btn-secondary px-8 py-3.5 rounded-[10px] text-sm" %>
          <% end %>
        </div>

        <!-- Metrics -->
        <div class="flex items-center gap-12">
          <div>
            <p class="text-[28px] font-bold tracking-tight" style="letter-spacing: -0.5px;">< 30 min</p>
            <p class="text-xs mt-1" style="color: var(--silver);">Full application</p>
          </div>
          <div class="w-px h-10" style="background: var(--border);"></div>
          <div>
            <p class="text-[28px] font-bold tracking-tight" style="letter-spacing: -0.5px;">3 sec</p>
            <p class="text-xs mt-1" style="color: var(--silver);">Document scan</p>
          </div>
          <div class="w-px h-10" style="background: var(--border);"></div>
          <div>
            <p class="text-[28px] font-bold tracking-tight" style="letter-spacing: -0.5px;">$0</p>
            <p class="text-xs mt-1" style="color: var(--silver);">Credit impact</p>
          </div>
        </div>
      </div>

      <!-- Right: Featured car -->
      <div class="scale-in hidden lg:block" style="animation-delay: 0.2s">
        <div class="border rounded-[20px] overflow-hidden" style="background: var(--bg-tertiary); border-color: var(--border);">
          <% featured = @vehicles.find(&:featured?) || @vehicles.first %>
          <% if featured %>
            <%= render "vehicles/car_3d", car_color: featured.hex_color, container_id: "hero-car", height: "h-[300px]", interactive: true %>
            <div class="px-6 py-5 flex items-center justify-between border-t bg-white" style="border-color: var(--border);">
              <div>
                <p class="font-semibold text-[15px]"><%= featured.display_name %></p>
                <p class="text-[13px] mt-0.5" style="color: var(--silver);"><%= featured.formatted_price %> &middot; <%= featured.formatted_mileage %></p>
              </div>
              <span class="text-[11px] font-semibold uppercase tracking-wide px-3 py-1.5 rounded-md" style="color: var(--accent); background: var(--accent-light); letter-spacing: 0.5px;">Featured</span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Trust bar -->
<div class="border-y" style="border-color: var(--border);">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-8 lg:px-16 py-5">
    <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-3">
      <span class="text-[10px] font-semibold tracking-[2px] uppercase" style="color: var(--silver);">Powered by</span>
      <span class="text-[13px] font-medium" style="color: #ccc;">Ruby on Rails</span>
      <span class="text-[13px] font-medium" style="color: #ccc;">Claude AI</span>
      <span class="text-[13px] font-medium" style="color: #ccc;">AWS Textract</span>
      <span class="text-[13px] font-medium" style="color: #ccc;">PostgreSQL</span>
      <span class="text-[13px] font-medium" style="color: #ccc;">Three.js</span>
    </div>
  </div>
</div>

<!-- Inventory -->
<section id="inventory" class="py-24">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-8 lg:px-16">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12">
      <div>
        <h2 class="font-serif text-[32px] font-normal" style="letter-spacing: -0.5px;">Available Vehicles</h2>
        <p class="text-[13px] mt-1" style="color: var(--silver);"><%= @vehicles.count %> vehicles ready for purchase</p>
      </div>
      <div class="flex items-center gap-1.5 text-xs" style="color: var(--silver);">
        <svg class="w-4 h-4" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        All vehicles include 100-day return policy
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <% @vehicles.each_with_index do |vehicle, i| %>
        <div class="card overflow-hidden fade-in" style="animation-delay: <%= i * 100 %>ms">
          <div class="relative" style="background: var(--bg-tertiary);">
            <%= render "vehicles/car_3d", car_color: vehicle.hex_color, container_id: "car-card-#{vehicle.id}", height: "h-[180px]", interactive: false %>
            <% if vehicle.featured? %>
              <span class="absolute top-3 left-3 text-[10px] font-semibold uppercase tracking-wide px-2.5 py-1 rounded-md z-10" style="background: var(--text-primary); color: #fff;">Featured</span>
            <% end %>
            <span class="absolute top-3 right-3 text-[10px] font-semibold px-2.5 py-1 rounded-md z-10 bg-white border" style="color: var(--text-muted); border-color: var(--border);"><%= vehicle.color %></span>
          </div>

          <div class="p-5">
            <h3 class="font-semibold text-[15px]"><%= vehicle.display_name %></h3>
            <p class="text-xs mt-0.5" style="color: var(--silver);"><%= vehicle.formatted_mileage %> &middot; Stock #<%= vehicle.stock_no %></p>

            <p class="text-[24px] font-bold tracking-tight mt-3 mb-0.5" style="letter-spacing: -0.5px;"><%= vehicle.formatted_price %></p>
            <p class="text-xs mb-4" style="color: var(--silver);">Est. <%= "$#{(vehicle.price * 0.018).to_i}" %>/mo with financing</p>

            <p class="text-[13px] leading-relaxed mb-4 line-clamp-2" style="color: var(--text-muted);"><%= vehicle.description %></p>

            <div class="flex gap-1.5 mb-4">
              <span class="text-[11px] font-medium px-2.5 py-1 rounded-md" style="background: var(--bg-tertiary); color: var(--text-muted);"><%= vehicle.year %></span>
              <span class="text-[11px] font-medium px-2.5 py-1 rounded-md" style="background: var(--bg-tertiary); color: var(--text-muted);"><%= vehicle.make %></span>
              <span class="text-[11px] font-medium px-2.5 py-1 rounded-md" style="background: var(--bg-tertiary); color: var(--text-muted);"><%= vehicle.color %></span>
            </div>

            <div class="grid grid-cols-2 gap-2">
              <%= link_to vehicle_path(vehicle), class: "text-center btn-secondary py-2.5 rounded-lg text-[13px] block" do %>
                View Details
              <% end %>
              <% if user_signed_in? %>
                <%= button_to onboarding_applications_path(vehicle_id: vehicle.id), method: :post,
                    class: "w-full btn-primary py-2.5 rounded-lg text-[13px] cursor-pointer" do %>
                  Start Purchase
                <% end %>
              <% else %>
                <%= link_to "Start Purchase", new_user_registration_path, class: "text-center btn-primary py-2.5 rounded-lg text-[13px] block" %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- How It Works -->
<section id="how-it-works" class="bg-white border-y" style="border-color: var(--border);">
  <div class="max-w-[960px] mx-auto px-5 sm:px-8 lg:px-16 py-24">
    <div class="text-center mb-16">
      <div class="text-[10px] font-semibold tracking-[2px] uppercase mb-3" style="color: var(--silver);">Simple Process</div>
      <h2 class="font-serif text-[32px] font-normal" style="letter-spacing: -0.5px;">How it works</h2>
      <p class="text-[15px] mt-2" style="color: var(--text-muted);">Three steps. Under 30 minutes. No dealership visit required.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-px rounded-2xl overflow-hidden" style="background: var(--border);">
      <div class="p-10 text-center" style="background: var(--bg-secondary);">
        <div class="text-[11px] font-semibold mb-4" style="color: var(--accent); letter-spacing: 1px;">01</div>
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4" style="background: var(--bg-tertiary);">
          <svg class="w-[22px] h-[22px]" style="color: var(--text-secondary);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>
        </div>
        <h3 class="font-semibold text-[15px] mb-2">AI Guides You</h3>
        <p class="text-[13px] leading-relaxed" style="color: var(--text-muted);">Ask questions about financing, trade-ins, or terms. Your AI assistant explains everything in plain English.</p>
      </div>
      <div class="p-10 text-center" style="background: var(--bg-secondary);">
        <div class="text-[11px] font-semibold mb-4" style="color: var(--accent); letter-spacing: 1px;">02</div>
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4" style="background: var(--bg-tertiary);">
          <svg class="w-[22px] h-[22px]" style="color: var(--text-secondary);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0z" /></svg>
        </div>
        <h3 class="font-semibold text-[15px] mb-2">Scan Documents</h3>
        <p class="text-[13px] leading-relaxed" style="color: var(--text-muted);">Point your camera at your license or pay stub. OCR extracts your data automatically in seconds.</p>
      </div>
      <div class="p-10 text-center" style="background: var(--bg-secondary);">
        <div class="text-[11px] font-semibold mb-4" style="color: var(--accent); letter-spacing: 1px;">03</div>
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mx-auto mb-4" style="background: var(--bg-tertiary);">
          <svg class="w-[22px] h-[22px]" style="color: var(--text-secondary);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" /></svg>
        </div>
        <h3 class="font-semibold text-[15px] mb-2">Get Your Keys</h3>
        <p class="text-[13px] leading-relaxed" style="color: var(--text-muted);">Complete your application in under 30 minutes. We deliver straight to your door.</p>
      </div>
    </div>
  </div>
</section>

<!-- Features -->
<section class="py-24">
  <div class="max-w-[1200px] mx-auto px-5 sm:px-8 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div>
        <div class="text-[10px] font-semibold tracking-[2px] uppercase mb-3" style="color: var(--silver);">AI Technology</div>
        <h2 class="font-serif text-[32px] font-normal leading-[1.2] mb-4" style="letter-spacing: -0.5px;">Powered by Claude AI &<br>AWS Textract</h2>
        <p class="text-[15px] leading-[1.7] mb-9" style="color: var(--text-muted);">Our AI chatbot understands your context at every step. Ask about APR, GAP insurance, or trade-in values and get clear, honest answers instantly.</p>

        <div class="space-y-5">
          <div class="flex gap-3.5">
            <div class="w-2 h-2 rounded-full mt-1.5 shrink-0" style="background: #22C55E;"></div>
            <div>
              <h4 class="font-semibold text-sm mb-0.5">Context-Aware Chatbot</h4>
              <p class="text-[13px] leading-relaxed" style="color: var(--text-muted);">Knows your vehicle, step, and application data. No repeating yourself.</p>
            </div>
          </div>
          <div class="flex gap-3.5">
            <div class="w-2 h-2 rounded-full mt-1.5 shrink-0" style="background: var(--accent);"></div>
            <div>
              <h4 class="font-semibold text-sm mb-0.5">Instant OCR Scanning</h4>
              <p class="text-[13px] leading-relaxed" style="color: var(--text-muted);">Snap a photo of your license, pay stub, or insurance. Fields auto-populate.</p>
            </div>
          </div>
          <div class="flex gap-3.5">
            <div class="w-2 h-2 rounded-full mt-1.5 shrink-0" style="background: #8B5CF6;"></div>
            <div>
              <h4 class="font-semibold text-sm mb-0.5">Interactive Loan Visualizer</h4>
              <p class="text-[13px] leading-relaxed" style="color: var(--text-muted);">See exactly what you'll pay monthly. Adjust terms and down payment in real time.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Chat mockup -->
      <div>
        <div class="bg-white border rounded-2xl overflow-hidden max-w-[380px] mx-auto" style="border-color: var(--border);">
          <div class="px-5 py-4 border-b flex items-center gap-2.5" style="border-color: var(--border);">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: var(--text-primary);">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
            </div>
            <div>
              <p class="text-[13px] font-semibold">Carvana AI</p>
              <p class="text-[11px]" style="color: #22C55E;">Online</p>
            </div>
          </div>
          <div class="px-5 py-4 flex flex-col gap-2.5">
            <div class="max-w-[80%] px-3.5 py-2.5 rounded-xl text-[13px] leading-relaxed self-start" style="background: var(--bg-tertiary); color: var(--text-secondary); border-bottom-left-radius: 4px;">What's the difference between APR and interest rate?</div>
            <div class="max-w-[80%] px-3.5 py-2.5 rounded-xl text-[13px] leading-relaxed text-white self-end" style="background: var(--text-primary); border-bottom-right-radius: 4px;"><strong>APR</strong> includes both the interest rate and fees, so it's the true cost of borrowing.</div>
            <div class="max-w-[80%] px-3.5 py-2.5 rounded-xl text-[13px] leading-relaxed self-start" style="background: var(--bg-tertiary); color: var(--text-secondary); border-bottom-left-radius: 4px;">Will this check hurt my credit score?</div>
            <div class="max-w-[80%] px-3.5 py-2.5 rounded-xl text-[13px] leading-relaxed text-white self-end" style="background: var(--text-primary); border-bottom-right-radius: 4px;">Not at all! This is a <strong>soft pull</strong> that won't affect your credit score.</div>
          </div>
          <div class="px-5 py-3 border-t flex gap-2 items-center" style="border-color: var(--border);">
            <div class="flex-1 h-9 rounded-lg flex items-center px-3 text-xs" style="background: var(--bg-tertiary); color: var(--silver);">Ask anything about financing...</div>
            <div class="w-9 h-9 rounded-lg flex items-center justify-center" style="background: var(--text-primary);">
              <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" /></svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section style="background: var(--text-primary);" class="py-24 text-center">
  <h2 class="font-serif text-[40px] font-normal text-white mb-3" style="letter-spacing: -1px;">Ready to get started?</h2>
  <p class="text-[15px] mb-9" style="color: var(--silver);">Browse our inventory, get pre-qualified in minutes, and have your car delivered to your door.</p>
  <% if user_signed_in? %>
    <a href="#inventory" class="inline-flex items-center gap-2 text-sm font-semibold px-8 py-3.5 rounded-[10px] bg-white" style="color: var(--text-primary);">
      Browse Vehicles
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
    </a>
  <% else %>
    <%= link_to new_user_registration_path, class: "inline-flex items-center gap-2 text-sm font-semibold px-8 py-3.5 rounded-[10px] bg-white", style: "color: var(--text-primary);" do %>
      Create Free Account
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
    <% end %>
  <% end %>
  <p class="text-xs mt-4" style="color: rgba(255,255,255,0.3);">Demo: demo@carvana.com / demo1234</p>
</section>

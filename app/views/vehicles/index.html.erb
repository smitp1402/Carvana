        <div class="absolute -z-10 inset-0 bg-gradient-to-br from-blue-100/30 via-indigo-50/20 to-purple-100/30 rounded-3xl blur-2xl scale-110"></div>
      </div>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="bg-neutral-900 text-white">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 lg:px-12 py-20 sm:py-24 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">Ready to get started?</h2>
    <p class="text-neutral-400 max-w-md mx-auto mb-10">Browse our inventory, get pre-qualified in minutes, and have your car delivered to your door.</p>
    <div class="flex flex-wrap justify-center gap-4">
      <% if user_signed_in? %>
        <a href="#inventory" class="btn-accent px-8 py-3.5 rounded-xl text-sm inline-flex items-center gap-2">
          Browse Vehicles
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
        </a>
      <% else %>
        <%= link_to new_user_registration_path, class: "btn-accent px-8 py-3.5 rounded-xl text-sm inline-flex items-center gap-2" do %>
          Create Free Account
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        <% end %>
      <% end %>
    </div>
    <p class="text-xs text-neutral-500 mt-6">Demo: demo@carvana.com / demo1234</p>
  </div>
</section>
